---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';
import DesignGallery from '../components/DesignGallery.astro';
---

<BaseLayout 
  title="Laboratorio Creativo Gráfico | Johan GC" 
  description="Galería inmersiva y bitácoras de producción gráfica avanzada, pre-prensa y UI/UX."
>
  <main data-theme="light" class="bg-slate-50 min-h-screen text-slate-900 transition-colors duration-500">
    
    <header class="py-20 px-6 max-w-6xl mx-auto border-b border-slate-200">
      <div class="space-y-4">
        <a href="/" class="text-xs font-mono text-indigo-600 hover:text-indigo-800 transition-colors inline-flex items-center gap-1">
          ← Volver al Inicio Principal
        </a>
        <h1 class="text-5xl md:text-6xl font-black tracking-tight text-slate-900 animate-fade-in">
          Laboratorio <br class="hidden md:inline"/> Creativo Gráfico
        </h1>
        <p class="text-base text-slate-500 max-w-xl font-light font-mono">
          [ Exploración de procesos de diseño, maquetación técnica y control estructural del píxel a la tinta ]
        </p>
      </div>
    </header>

    <section class="py-16 px-6 max-w-6xl mx-auto">
      <DesignGallery />
    </section>

  </main>
  
  <Footer />
</BaseLayout>