---
// src/pages/projects/[id].astro
import BaseLayout from '../../layouts/BaseLayout.astro';

const miSlidePersonalizado = {
  forwards: {
    old: { name: 'astroSlideToLeft', duration: '500ms', easing: 'ease-out' },
    new: { name: 'astroSlideFromRight', duration: '500ms', easing: 'ease-out' }
  },
  backwards: {
    old: { name: 'astroSlideToRight', duration: '500ms', easing: 'ease-out' },
    new: { name: 'astroSlideFromLeft', duration: '500ms', easing: 'ease-out' }
  }
};

export function getStaticPaths() {
  return [
    { 
      params: { id: 'prepress-auto' },
      props: {
        title: "Automatización de Preprensa Digital",
        category: "Bitácora / Ingeniería Gráfica",
        fullDesc: "Desarrollo de un ecosistema de formularios inteligentes en Adobe Acrobat que automatizan el cálculo de tintas y marcas de corte, reduciendo el error humano en un 40%.",
        challenge: "Los operarios de producción perdían valioso tiempo de máquina configurando manualmente especificaciones mecánicas propensas a errores.",
        solution: "Implementación de lógica condicional incrustada y scripts en PDF para ocultar pares directos de control redundantes y asegurar un estándar de salida exacto.",
        processImages: [
          "https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?auto=format&fit=crop&w=600&q=80",
          "https://images.unsplash.com/photo-1620641788421-7a1c342ea42e?auto=format&fit=crop&w=600&q=80"
        ]
      }
    },
  ];
}

const { title, category, fullDesc, challenge, solution, processImages } = Astro.props;
---

{/* CORREGIDO: Se pasan las Props requeridas por tu Layout */}
<BaseLayout title={title} description={fullDesc}>
  <div 
    transition:animate={miSlidePersonalizado}
    class="min-h-screen w-full bg-slate-50/50 flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8"
  >
    {/* CORREGIDO: rounded-[2rem] cambiado por la clase canónica rounded-4xl */}
    <div class="max-w-4xl w-full bg-white rounded-4xl border border-slate-200/80 shadow-xl p-8 md:p-12 space-y-10">
      
      <div class="flex items-center justify-between border-b border-slate-100 pb-6">
        <span class="text-[11px] font-mono uppercase tracking-widest text-indigo-600 font-bold">
          // {category}
        </span>
        <button 
          onclick="history.back()" 
          class="text-xs font-mono font-bold text-slate-400 hover:text-slate-900 bg-slate-50 hover:bg-slate-100 px-4 py-2 rounded-xl border border-slate-200/60 transition-all"
        >
          // CERRAR [X]
        </button>
      </div>

      <div class="space-y-6">
        <h1 class="text-3xl md:text-4xl font-black tracking-tight text-slate-900">
          {title}
        </h1>
        <p class="text-base text-slate-600 font-light leading-relaxed max-w-2xl">
          {fullDesc}
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 pt-4">
        <div class="space-y-3 p-6 rounded-2xl bg-slate-50/50 border border-slate-100">
          <h3 class="font-mono text-xs font-bold uppercase tracking-wider text-slate-400">// EL DESAFÍO</h3>
          <p class="text-sm text-slate-600 font-light leading-relaxed">{challenge}</p>
        </div>
        
        <div class="space-y-3 p-6 rounded-2xl bg-indigo-50/30 border border-indigo-50/80">
          <h3 class="font-mono text-xs font-bold uppercase tracking-wider text-indigo-500">// RESOLUCIÓN APLICADA</h3>
          <p class="text-sm text-slate-600 font-light leading-relaxed">{solution}</p>
        </div>
      </div>

      <div class="space-y-4 pt-6 border-t border-slate-100">
        <h3 class="font-mono text-xs font-bold uppercase tracking-wider text-slate-400 text-center">
          EVIDENCIAS TÉCNICAS DEL PROCESO
        </h3>
        
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 pt-2">
          {processImages.map((img, idx) => (
            <div class="group space-y-2">
              <div class="rounded-2xl overflow-hidden border border-slate-200/80 bg-white shadow-sm transition-transform duration-500 group-hover:scale-[1.01]">
                {/* CORREGIDO: aspect-[4/3] cambiado por la clase canónica aspect-4/3 */}
                <img 
                  src={img} 
                  alt={`Validación Estructural ${idx + 1}`} 
                  class="w-full h-auto object-cover aspect-4/3"
                  loading="lazy" 
                />
              </div>
              <span class="text-[10px] font-mono text-slate-400 block text-center">
                Fase de Validación Estructural {idx + 1}
              </span>
            </div>
          ))}
        </div>
      </div>

    </div>
  </div>
</BaseLayout>