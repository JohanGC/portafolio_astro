---
// Importamos nuestro Layout base estructurado en el módulo anterior
import BaseLayout from '../layouts/BaseLayout.astro';
// 1. Importamos el componente reutilizable de forma segura
import ProjectCard from '../components/ProjectCard.astro';
import AboutMe from '../components/AboutMe.astro';
import ContactForm from '../components/ContactForm.astro';
import Footer from '../components/Footer.astro';
import DesignGallery from '../components/DesignGallery.astro';
---

<BaseLayout 
  title="Johan GC | Portafolio Híbrido: Software, Diseño & Seguridad" 
  description="Portafolio profesional que integra ingeniería de software, producción gráfica avanzada y auditoría de seguridad en interfaces."
>
  <main class="w-full overflow-x-hidden">
    
    <section 
      id="intro-design" 
      data-theme="light" 
      class="min-h-screen flex items-center justify-center relative overflow-hidden w-full max-w-none px-6 md:px-16 lg:px-24"
    >
      <div class="w-full grid grid-cols-1 lg:grid-cols-12 items-center gap-12 relative z-10">
        <div class="lg:col-span-9 space-y-6">
          <span class="text-xs font-mono uppercase tracking-widest text-emerald-500 bg-emerald-50 px-3 py-1 rounded-full font-bold inline-block">
            [ 9no Semestre Ingeniería de Software + Experto Preprensa ]
          </span>
        
          <h1 class="text-5xl md:text-7xl lg:text-8xl font-extrabold tracking-tight leading-none">
            Diseño interfaces de alta fidelidad, <br />
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-600 to-violet-600">
              programo código robusto
            </span> <br />
            y audito su seguridad.
          </h1>
          <p class="text-lg text-slate-600 max-w-3xl font-light leading-relaxed">
            Un enfoque híbrido que fusiona siete años de experiencia en procesos de producción gráfica avanzada con ingeniería de software táctica y mitigación de vulnerabilidades AppSec.
          </p>
        </div>
      </div>
    </section>

    <DesignGallery />

    <AboutMe />

    <section 
      id="security-core" 
      data-theme="dark" 
      class="min-h-screen py-32 w-full max-w-none px-6 md:px-16 lg:px-24 transition-colors duration-500 bg-slate-950 text-slate-100 relative overflow-hidden border-t border-slate-900"
    >
      <div class="w-full space-y-16 relative z-10">
        
        <div class="space-y-4">
          <span class="text-xs font-mono uppercase tracking-widest text-emerald-400 bg-emerald-950/50 border border-emerald-800/60 px-3 py-1 rounded-full">
            $ nmap -sV -p 443 auditoria_ui
          </span>
          <h2 class="text-4xl md:text-6xl font-black tracking-tight text-slate-100">
            Seguridad Ofensiva y Desarrollo de Software
          </h2>
          <p class="text-sm text-slate-400 max-w-2xl font-light">
            Haz clic en cualquiera de las auditorías tácticas a continuación para desplegar el reporte técnico completo, su Prueba de Concepto (PoC) y código de mitigación.
          </p>
        </div>

        <div class="grid grid-cols-1 xl:grid-cols-2 gap-8 w-full">
          <div 
            data-security-id="appsec-interface"
            class="p-8 rounded-2xl border border-slate-900 bg-slate-900/40 hover:bg-slate-900/70 hover:border-emerald-500/40 hover:shadow-2xl hover:shadow-emerald-500/5 transition-all duration-300 flex flex-col justify-between group cursor-pointer"
          >
            <div class="space-y-4">
              <div class="flex items-center justify-between">
                <span class="text-[10px] font-mono px-2.5 py-1 rounded-md border border-emerald-900/50 bg-emerald-950/40 text-emerald-400 uppercase tracking-wider font-bold">
                  AppSec
                </span>
              </div>
              <h3 class="text-2xl font-bold tracking-tight text-slate-100 group-hover:text-emerald-400 transition-colors">
                Auditoría de Vulnerabilidades en Interfaces de Usuario
              </h3>
              <p class="text-sm leading-relaxed font-light text-slate-400">
                Análisis técnico ofensivo de aplicaciones web utilizando metodologías OWASP. Detección y mitigación de fallos de Cross-Site Scripting (XSS) y manipulación de parámetros con Burp Suite y Kali Linux.
              </p>
            </div>
            <div class="mt-8 space-y-4">
              <div class="flex flex-wrap gap-2">
                {['Kali Linux', 'Burp Suite', 'OWASP ZAP', 'Mitigación DOM'].map(tag => (
                  <span class="text-xs font-mono px-2 py-0.5 rounded bg-slate-950 border border-slate-800 text-slate-400">{tag}</span>
                ))}
              </div>
              <div class="pt-2">
                <span class="text-xs font-mono font-bold uppercase tracking-wider text-emerald-400 inline-flex items-center gap-1 group-hover:translate-x-1 transition-transform">
                  Desplegar Bitácora Técnica ➔
                </span>
              </div>
            </div>
          </div>

          <div 
            data-security-id="cloud-architecture"
            class="p-8 rounded-2xl border border-slate-900 bg-slate-900/40 hover:bg-slate-900/70 hover:border-emerald-500/40 hover:shadow-2xl hover:shadow-emerald-500/5 transition-all duration-300 flex flex-col justify-between group cursor-pointer"
          >
            <div class="space-y-4">
              <div class="flex items-center justify-between">
                <span class="text-[10px] font-mono px-2.5 py-1 rounded-md border border-emerald-900/50 bg-emerald-950/40 text-emerald-400 uppercase tracking-wider font-bold">
                  Cloud Security
                </span>
              </div>
              <h3 class="text-2xl font-bold tracking-tight text-slate-100 group-hover:text-emerald-400 transition-colors">
                Arquitectura Cloud Segura y Despliegue Automatizado
              </h3>
              <p class="text-sm leading-relaxed font-light text-slate-400">
                Diseño e implementación de infraestructura en la nube utilizando servicios de AWS. Configuración de políticas estrictas de acceso (IAM), bases de datos relacionales seguras (RDS) y hardening de servidores EC2.
              </p>
            </div>
            <div class="mt-8 space-y-4">
              <div class="flex flex-wrap gap-2">
                {['AWS', 'IAM Hardening', 'VPC Isolation', 'SecOps'].map(tag => (
                  <span class="text-xs font-mono px-2 py-0.5 rounded bg-slate-950 border border-slate-800 text-slate-400">{tag}</span>
                ))}
              </div>
              <div class="pt-2">
                <span class="text-xs font-mono font-bold uppercase tracking-wider text-emerald-400 inline-flex items-center gap-1 group-hover:translate-x-1 transition-transform">
                  Desplegar Bitácora Técnica ➔
                </span>
              </div>
            </div>
          </div>
        </div>

        <div class="pt-4 flex justify-end">
          <a 
            href="/seguridad" 
            class="group inline-flex items-center gap-3 px-6 py-3 border border-emerald-500/20 bg-slate-900/40 text-emerald-400 font-mono text-xs font-bold uppercase tracking-wider rounded-xl hover:bg-emerald-500 hover:text-slate-950 hover:border-emerald-500 transition-all duration-300 shadow-lg shadow-emerald-500/5 cursor-pointer"
          >
            <span>Ver Todos los Writeups de Seguridad</span>
            <span class="transform group-hover:translate-x-1.5 transition-transform inline-block">➔</span>
          </a>
        </div>

      </div>

      <div 
        id="index-sec-modal-overlay" 
        class="fixed inset-0 z-50 bg-slate-950/90 backdrop-blur-md flex items-center justify-center p-4 md:p-6 opacity-0 pointer-events-none transition-opacity duration-300"
      >
        <div 
          id="index-sec-modal-card" 
          class="bg-slate-900 border border-slate-800 w-full max-w-3xl rounded-2xl max-h-[85vh] overflow-y-auto shadow-2xl flex flex-col transition-transform duration-300 scale-95 text-slate-100"
        >
          <div class="p-6 border-b border-slate-800 flex justify-between items-center sticky top-0 bg-slate-900 z-10">
            <div>
              <span id="index-modal-category" class="text-[10px] font-mono text-emerald-400 uppercase tracking-widest block mb-1">
                CORE_AUDIT_LOG
              </span>
              <h3 id="index-modal-title" class="text-xl font-black tracking-tight text-slate-100">
                Cargando...
              </h3>
            </div>
            <button 
              id="index-sec-modal-close"
              class="p-2 rounded-lg bg-slate-800/50 border border-slate-700/50 text-slate-400 hover:text-white hover:bg-slate-800 transition-colors font-mono text-xs cursor-pointer"
            >
              [ ESC_CLOSE ]
            </button>
          </div>

          <div id="index-modal-content" class="p-6 space-y-6 text-sm text-slate-300 leading-relaxed">
            </div>
        </div>
      </div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-emerald-500/5 rounded-full blur-3xl pointer-events-none z-0"></div>
    </section>

    <ContactForm />

  </main>
  
  <Footer />
</BaseLayout>

<script>
  const securityCases = {
    "appsec-interface": {
      title: "Auditoría de Vulnerabilidades en Interfaces de Usuario",
      category: "AppSec / Pentesting Web",
      scenario: "Simulación controlada sobre pasarelas de entrada de datos y variables de frontend vulnerables a inyecciones lógicas de scripts cruzados.",
      recon: "Mapeo manual de interceptación utilizando Burp Suite Proxy. Se identificaron nodos reflejados que no sanitizaban cadenas HTML antes de renderizarlas en el árbol DOM del navegador.",
      pocCommand: "$ burp-suite --target https://api.produccion.local/ui-validator",
      pocText: "Al inyectar payloads avanzados con etiquetas malformadas, se logró saltar las comprobaciones básicas de frontend basadas únicamente en expresiones regulares débiles, logrando la ejecución de código JavaScript arbitrario.",
      solution: "Implementación estricta de funciones nativas de codificación de caracteres especiales (HTML Entities encoding), desactivación de directivas reactivas inseguras (`innerHTML`) y despliegue de una política CSP estricta.",
      mitigationCode: `// Asegurando la sanitización completa en el árbol de renderizado\nfunction safeRender(userInput) {\n  const textNode = document.createTextNode(userInput);\n  const displayContainer = document.getElementById('output');\n  displayContainer.textContent = textNode.textContent;\n}`
    },
    "cloud-architecture": {
      title: "Arquitectura Cloud Segura y Despliegue Automatizado",
      category: "Cloud Security & Infrastructure",
      scenario: "Hardening y aislamiento perimetral de una topología de microservicios corporativos expuestos a riesgos de escalada de privilegios laterales.",
      recon: "Auditoría de red mediante herramientas de escaneo y AWS IAM Policy Simulator. Se descubrieron grupos de seguridad globales con el puerto de administración remota SSH (22) abierto a la WAN (`0.0.0.0/0`) y políticas IAM comodín.",
      pocCommand: "# aws iam simulate-principal-policy --action-names ec2:DeleteVolume",
      pocText: "Debido a una asignación incorrecta de roles asociados a instancias de cómputo perimetrales (EC2), se demostró un vector crítico que permitía a un de un atacante comprometer discos duros de almacenamiento elástico de forma remota.",
      solution: "Rediseño completo de la VPC segmentando bases de datos en subredes privadas aisladas de internet, enrutamiento a través de NAT Gateways y limitación granular estricta de políticas de IAM bajo el principio de menor privilegio.",
      mitigationCode: `# Política IAM en formato JSON con alcance restringido por ARN\n{\n  "Version": "2012-10-17",\n  "Statement": [{\n    "Effect": "Allow",\n    "Action": ["s3:GetObject"],\n    "Resource": ["arn:aws:s3:::datos-privados-produccion/*"]\n  }]\n}`
    }
  };

  const cards = document.querySelectorAll('div[data-security-id]');
  const overlay = document.getElementById('index-sec-modal-overlay');
  const cardContainer = document.getElementById('index-sec-modal-card');
  const closeBtn = document.getElementById('index-sec-modal-close');
  
  const mTitle = document.getElementById('index-modal-title');
  const mCategory = document.getElementById('index-modal-category');
  const mContent = document.getElementById('index-modal-content');
  const htmlBody = document.body;

  cards.forEach(card => {
    card.addEventListener('click', () => {
      const id = card.getAttribute('data-security-id');
      const data = securityCases[id as keyof typeof securityCases];

      if (data && overlay && cardContainer && mTitle && mCategory && mContent) {
        mTitle.textContent = data.title;
        mCategory.textContent = `[ WRITEUP_RECOVERY // ${data.category} ]`;
        
        mContent.innerHTML = `
          <div class="space-y-2">
            <h4 class="font-mono text-xs text-slate-400 font-bold uppercase tracking-wider">// 01. ESCENARIO DE LA INVESTIGACIÓN</h4>
            <p class="font-light text-slate-300 bg-slate-950/40 p-4 border border-slate-800/60 rounded-xl">${data.scenario}</p>
          </div>

          <div class="space-y-2">
            <h4 class="font-mono text-xs text-slate-400 font-bold uppercase tracking-wider">// 02. RECONOCIMIENTO Y VECTORES</h4>
            <p class="font-light text-slate-300 bg-slate-950/40 p-4 border border-slate-800/60 rounded-xl">${data.recon}</p>
          </div>

          <div class="space-y-3">
            <h4 class="font-mono text-xs text-slate-400 font-bold uppercase tracking-wider">// 03. PRUEBA DE CONCEPTO (PoC) EXPLOIT</h4>
            <div class="bg-slate-950 rounded-xl p-4 font-mono text-xs border border-slate-800 space-y-2 shadow-inner">
              <span class="text-emerald-400">${data.pocCommand}</span>
              <p class="text-slate-400 font-sans mt-2 leading-relaxed">${data.pocText}</p>
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 pt-2">
            <div class="space-y-2">
              <h4 class="font-mono text-xs text-emerald-400 font-bold uppercase tracking-wider">// 04. REMEDIACIÓN</h4>
              <p class="font-light text-slate-300 bg-emerald-950/10 p-4 border border-emerald-900/30 rounded-xl h-full">${data.solution}</p>
            </div>
            <div class="space-y-2">
              <h4 class="font-mono text-xs text-slate-400 font-bold uppercase tracking-wider">// 05. PARCHE SEGURO</h4>
              <pre class="bg-slate-950 text-slate-300 p-4 rounded-xl border border-slate-800 font-mono text-[11px] overflow-x-auto shadow-inner leading-relaxed"><code>${data.mitigationCode}</code></pre>
            </div>
          </div>
        `;

        overlay.classList.remove('opacity-0', 'pointer-events-none');
        overlay.classList.add('opacity-100', 'pointer-events-auto');
        cardContainer.classList.remove('scale-95');
        cardContainer.classList.add('scale-100');
        htmlBody.style.overflow = 'hidden';
      }
    });
  });

  const closeModal = () => {
    if (overlay && cardContainer) {
      overlay.classList.add('opacity-0', 'pointer-events-none');
      overlay.classList.remove('opacity-100', 'pointer-events-auto');
      cardContainer.classList.add('scale-95');
      cardContainer.classList.remove('scale-100');
      htmlBody.style.overflow = '';
    }
  };

  if (closeBtn) closeBtn.addEventListener('click', closeModal);
  if (overlay) {
    overlay.addEventListener('click', (e) => {
      if (e.target === overlay) closeModal();
    });
  }
</script>