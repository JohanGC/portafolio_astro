---
// Importamos nuestro Layout base estructurado en el módulo anterior
import BaseLayout from '../layouts/BaseLayout.astro';
// 1. Importamos el componente reutilizable de forma segura
import ProjectCard from '../components/ProjectCard.astro';
import AboutMe from '../components/AboutMe.astro';
import ContactForm from '../components/ContactForm.astro';
import Footer from '../components/Footer.astro';
import DesignGallery from '../components/DesignGallery.astro';
---

<BaseLayout 
  title="Johan GC | Portafolio Híbrido: Software, Diseño & Seguridad" 
  description="Portafolio profesional que integra ingeniería de software, producción gráfica avanzada y auditoría de seguridad en interfaces."
>
  <main>
    
  <section 
    id="intro-design" 
    data-theme="light" 
    class="min-h-screen flex items-center justify-center relative overflow-hidden"
  >
    <div class="max-w-6xl mx-auto px-6 grid grid-cols-1 md:grid-cols-12 items-center gap-12 relative z-10">
      <div class="md:col-span-8 space-y-6">
        <span class="text-xs font-mono uppercase tracking-widest text-indigo-600 bg-indigo-50 px-3 py-1 rounded-full font-bold">
          [cite: 111]
          [ 9no Semestre Ingeniería de Software + Experto Preprensa ]
        </span>
      
        <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight">
          [cite: 113]
          Diseño interfaces de alta fidelidad, <br />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-600 to-violet-600">
            [cite: 112]
            programo código robusto
          </span> 
          y audito su seguridad.
        </h1>
        <p class="text-lg text-slate-600 max-w-2xl font-light">
          [cite: 114]
          Especializado en optimizar flujos de producción digital, desarrollar formularios interactivos avanzados y mitigar vulnerabilidades críticas en la experiencia del usuario.
        </p>
      </div>

      <div class="md:col-span-4 flex items-center justify-center relative">
        <img 
          src="/foto-perfil.jpg" 
          alt="Foto de perfil de Johan González" 
          class="aspect-square w-full max-w-[320px] rounded-full object-cover shadow-xl border-4 border-indigo-100"
        />
        </div>
    </div>

    <div class="absolute inset-0 z-0 flex items-center justify-center opacity-30">
      <div class="w-[500px] h-[500px] rounded-full bg-gradient-to-r from-indigo-200 to-violet-200 blur-3xl"></div>
    </div>
  </section>

    <section 
      id="security-core" 
      data-theme="dark" 
      class="min-h-screen flex flex-col justify-center px-6 py-20 transition-all"
    >
      <div class="max-w-5xl mx-auto w-full space-y-12">
        <div class="space-y-4">
          <span class="text-xs font-mono uppercase tracking-widest text-emerald-400 bg-emerald-950/50 border border-emerald-800/60 px-3 py-1 rounded-full">
            $ cd /home/kali/auditoria_ui
          </span>
          <h2 class="text-4xl md:text-5xl font-bold tracking-tight">
            Defensa en Profundidad desde la Interfaz
          </h2>
          <p class="text-slate-400 max-w-2xl font-light">
            No asumo que los datos del cliente son seguros. Utilizo metodologías de OWASP y análisis técnico con herramientas como Burp Suite y Kali Linux para garantizar que la experiencia visual no comprometa los datos del backend.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 font-mono">
          <div class="p-6 rounded-xl bg-slate-900 border border-slate-800 hover:border-emerald-500/40 transition-colors">
            <div class="text-emerald-400 mb-2">⚡ AWS & Cloud</div>
            <p class="text-xs text-slate-400 font-sans">Estructuración y despliegue de soluciones seguras en la nube bajo arquitecturas escalables.</p>
          </div>
          <div class="p-6 rounded-xl bg-slate-900 border border-slate-800 hover:border-emerald-500/40 transition-colors">
            <div class="text-emerald-400 mb-2">🛡️ Fortinet NSE</div>
            <p class="text-xs text-slate-400 font-sans">Comprensión sistémica de perímetros de red, políticas de seguridad y análisis de amenazas.</p>
          </div>
          <div class="p-6 rounded-xl bg-slate-900 border border-slate-800 hover:border-emerald-500/40 transition-colors">
            <div class="text-emerald-400 mb-2">🔍 OWASP & Pentesting</div>
            <p class="text-xs text-slate-400 font-sans">Detección temprana de vulnerabilidades web como XSS, inyecciones de datos y fallos lógicos.</p>
          </div>
        </div>
      </div>
    </section>

    <section id="intro-design" data-theme="light" class="min-h-screen py-20 px-6">
      <div class="max-w-5xl mx-auto space-y-16">
        
        <div class="space-y-4">
          <span class="text-xs font-mono uppercase tracking-widest text-indigo-600 bg-indigo-50 px-3 py-1 rounded-full font-bold">
            [ Producción Gráfica & UX/UI ]
          </span>
          <h1 class="text-5xl md:text-6xl font-extrabold tracking-tight">
            Optimización Visual e Interactividad Avanzada.
          </h1>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <ProjectCard 
            title="Sistemas de Automatización de Formularios Digitales"
            description="Rediseño y reestructuración lógica de formularios PDF interactivos en Adobe Acrobat para flujos empresariales. Implementación de scripts de validación en cascada y optimización de arquitectura de datos."
            tags={['Adobe Acrobat', 'JavaScript', 'UI Design', 'Prepress']}
            category="design"
          />
          <ProjectCard 
            title="Prototipado de Alta Fidelidad para Plataformas Web"
            description="Arquitectura de información y diseño de interfaces (UI) responsivas orientadas a la conversión de usuarios. Creación de sistemas de diseño escalables y componentes atómicos."
            tags={['Figma', 'UX Research', 'Design Systems', 'Prototyping']}
            category="design"
          />
        </div>

      </div>
    </section>
    
    <section 
      id="intro-design" 
      data-theme="light" 
      class="min-h-screen flex flex-col justify-center py-24 px-6 max-w-5xl mx-auto transition-colors duration-500"
    >
      <div class="space-y-12">
        
        <div class="space-y-4">
          <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight text-slate-900blue">
            Diseño, Preprensa. <br />
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-600 to-violet-600">
              diseño interfaces de código robusto
            </span> 
          </h1>
          <p class="text-lg text-slate-600 max-w-2xl font-light">
            Especializado en optimizar flujos de producción digital, desarrollar formularios interactivos avanzados y mitigar vulnerabilidades críticas en la experiencia del usuario.
          </p>
        </div>

        <div class="space-y-8">
          <h2 class="text-xs font-mono uppercase tracking-wider text-slate-400 block border-b border-slate-100 pb-2">
            Casos de Estudio Destacados
          </h2>
          
          <DesignGallery limit={3} />

          <div class="pt-4 flex justify-end">
            <a 
              href="/diseno" 
              class="group inline-flex items-center gap-3 px-6 py-3 border-2 border-slate-900 text-slate-900 font-mono text-xs font-bold uppercase tracking-wider rounded-xl hover:bg-slate-900 hover:text-white transition-all duration-300 shadow-sm"
            >
              <span>Explorar Laboratorio Completo</span>
              <span class="transform group-hover:translate-x-1.5 transition-transform inline-block">➔</span>
            </a>
          </div>
        </div>

      </div>
    </section>

    <section 
      id="security-core" 
      data-theme="dark" 
      class="py-24 px-6 transition-colors duration-500"
    >
      <div class="max-w-5xl mx-auto space-y-12">
        
        <div class="space-y-4">
          <span class="inline-block text-xs font-mono uppercase tracking-widest text-emerald-400 bg-emerald-950/50 border border-emerald-800/60 px-3 py-1 rounded-full">
            $ nmap -sV -p 443 auditoria_ui
          </span>
          <h2 class="text-4xl md:text-5xl font-bold tracking-tight text-slate-100">
            Seguridad Ofensiva y Desarrollo de Software
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <ProjectCard 
            title="Auditoría de Vulnerabilidades en Interfaces de Usuario"
            description="Análisis técnico ofensivo de aplicaciones web utilizando metodologías OWASP. Detección y mitigación de fallos de Cross-Site Scripting (XSS) y manipulación de parámetros con Burp Suite y Kali Linux."
            tags={['Kali Linux', 'Burp Suite', 'OWASP ZAP', 'AppSec']}
            category="security"
          />
          <ProjectCard 
            title="Arquitectura Cloud Segura y Despliegue Automatizado"
            description="Diseño e implementación de infraestructura en la nube utilizando servicios de AWS. Configuración de políticas estrictas de acceso (IAM), bases de datos relacionales seguras (RDS) y hardening de servidores EC2."
            tags={['AWS', 'Cloud Security', 'IAM', 'Network Security']}
            category="security"
          />
        </div>

        <div class="pt-4 flex justify-end">
          <a 
            href="/seguridad" 
            class="group inline-flex items-center gap-3 px-6 py-3 border-2 border-emerald-500/30 bg-slate-900/40 text-emerald-400 font-mono text-xs font-bold uppercase tracking-wider rounded-xl hover:bg-emerald-500 hover:text-slate-950 hover:border-emerald-500 hover:font-extrabold transition-all duration-300 shadow-lg shadow-emerald-500/5 cursor-pointer"
          >
            <span>Acceder al Centro de Operaciones (SOC)</span>
            <span class="transform group-hover:translate-x-1.5 transition-transform inline-block">➔</span>
          </a>
        </div>

      </div>
    </section>


    <AboutMe />

    <ContactForm />

  </main>
  <Footer />
</BaseLayout>