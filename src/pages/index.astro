---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import AboutMe from '../components/AboutMe.astro';
import ContactForm from '../components/ContactForm.astro';
import Footer from '../components/Footer.astro';
import DesignGallery from '../components/DesignGallery.astro';
---

<BaseLayout 
  title="Johan GC | Portafolio Híbrido: Software, Diseño & Seguridad" 
  description="Portafolio profesional que integra ingeniería de software, producción gráfica avanzada y auditoría de seguridad en interfaces."
>
  <main class="w-full overflow-x-hidden">
    
    <section 
      id="intro-design" 
      data-theme="light" 
      class="min-h-screen flex items-center justify-center relative overflow-hidden w-full max-w-none px-6 md:px-16 lg:px-24 bg-slate-50/50"
      >
      <div class="absolute inset-0 bg-[linear-gradient(to_right,#e2e8f0_1px,transparent_1px),linear-gradient(to_bottom,#e2e8f0_1px,transparent_1px)] bg-size[4rem_4rem] mask-[radial-gradient(ellipse_60%_50%_at_50%_50%,#000_70%,transparent_100%)] opacity-70" />
      
      <div class="w-full grid grid-cols-1 lg:grid-cols-12 items-center gap-12 relative z-10">
        <div class="lg:col-span-9 space-y-6">
          <span class="text-xs font-mono uppercase tracking-widest text-emerald-500 bg-emerald-50 px-3 py-1 rounded-full font-bold inline-block">
            [ 9no Semestre Ingeniería de Software + Experto Preprensa ]
          </span>
        
          <h1 class="text-4xl md:text-7xl font-extrabold tracking-tight text-slate-900 leading-none">
            Diseño interfaces de alta fidelidad, <br/>
            <span class="text-indigo-600">automatizo preprensa</span> y <br class="hidden md:inline"/> 
            audito la seguridad de tu código.
          </h1>
          
          <p class="text-base md:text-xl text-slate-500 font-light max-w-2xl leading-relaxed">
            Un perfil híbrido enfocado en la convergencia entre el rigor algorítmico, el control estructural del pixel a la tinta y la mitigación proactiva de vulnerabilidades.
          </p>
          
          <div class="pt-4 flex flex-wrap gap-4 font-mono text-xs">
            <a href="#about-section" class="bg-slate-900 hover:bg-slate-800 text-white font-bold px-6 py-3.5 rounded-xl transition-all shadow-lg active:scale-[0.98]">
              // DESPLEGAR_PERFIL
            </a>
            <a href="#contact" class="bg-white border border-slate-200 hover:border-slate-300 text-slate-600 font-bold px-6 py-3.5 rounded-xl transition-all shadow-sm active:scale-[0.98]">
              // CONTACTAR
            </a>
          </div>
        </div>
      </div>
    </section>

    <AboutMe />

    <section id="creative-lab" data-theme="light" class="py-32 bg-white text-slate-900 transition-colors duration-500 border-t border-slate-100 px-6 md:px-16 lg:px-24 w-full max-w-none">
      <div class="w-full space-y-16">
        
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 border-b border-slate-200 pb-8">
          <div class="space-y-3">
            <span class="text-xs font-mono uppercase tracking-widest text-indigo-600 bg-indigo-50 border border-indigo-100 px-3 py-1 rounded-full inline-block font-bold">
              [ CONTROL ESTRECHO DEL PÍXEL A LA TINTA ]
            </span>
            <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-slate-900">
              Ecosistema Gráfico Industrial
            </h2>
          </div>
          <a href="/diseno" class="text-xs font-mono font-bold uppercase text-indigo-600 hover:text-indigo-800 transition-colors border border-slate-200 bg-slate-50 px-4 py-2 rounded-xl shadow-sm">
            Ver Laboratorio Gráfico →
          </a>
        </div>

        <DesignGallery limit={2} />

      </div>
    </section>

    <section id="software-security" data-theme="dark" class="py-32 bg-slate-950 text-slate-100 transition-colors duration-500 px-6 md:px-16 lg:px-24 w-full max-w-none border-t border-slate-900">
      <div class="w-full space-y-16">
        
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 border-b border-slate-900 pb-8">
          <div class="space-y-3">
            <span class="text-xs font-mono uppercase tracking-widest text-emerald-400 bg-emerald-950/30 border border-emerald-900/40 px-3 py-1 rounded-full inline-block font-bold">
              [ INGENIERÍA DE SOFTWARE & AUDITORÍA DE SEGURIDAD ]
            </span>
            <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-slate-100 uppercase">
              Soluciones Robustas y Seguras
            </h2>
          </div>
          <a href="/seguridad" class="text-xs font-mono font-bold uppercase text-emerald-400 hover:text-emerald-300 transition-colors border border-emerald-900/60 bg-emerald-950/10 px-4 py-2 rounded-xl shadow-lg">
            Acceder al Lab de Seguridad →
          </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 w-full">
          <ProjectCard 
            title="Auditoría de Vulnerabilidades Web (OWASP Top 10)"
            description="Detección, explotación controlada y parcheo estructural de fallos severos de inyección y fallos de sanitización en componentes frontend."
            tags={['Burp Suite', 'OWASP ZAP', 'Kali Linux', 'AppSec']}
            category="security"
            link="/seguridad"
          />
          <ProjectCard 
            title="Arquitectura de Nube Inmune"
            description="Diseño e implementación de infraestructuras en AWS aplicando políticas estrictas de acceso (IAM), bases de datos relacionales seguras (RDS) y hardening de servidores EC2."
            tags={['AWS', 'Cloud Security', 'IAM', 'Network Security']}
            category="security"
            link="/seguridad"
          />
        </div>

      </div>
    </section>



    <ContactForm />
    <Footer />

  </main>
</BaseLayout>