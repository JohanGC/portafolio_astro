---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import AboutMe from '../components/AboutMe.astro';
import ContactForm from '../components/ContactForm.astro';
import Footer from '../components/Footer.astro';
import DesignGallery from '../components/DesignGallery.astro';
---

<BaseLayout 
  title="Johan GC | Portafolio Híbrido: Software, Diseño & Seguridad" 
  description="Portafolio profesional que integra ingeniería de software, producción gráfica avanzada y auditoría de seguridad en interfaces."
>
  <main class="w-full overflow-x-hidden">
    
    <section 
      id="intro-design" 
      data-theme="light" 
      class="min-h-screen flex items-center justify-center relative overflow-hidden w-full max-w-none px-6 md:px-16 lg:px-24 bg-slate-50/50"
    >
      <div class="absolute inset-0 bg-[linear-gradient(to_right,#e2e8f0_1px,transparent_1px),linear-gradient(to_bottom,#e2e8f0_1px,transparent_1px)] bg-size-[4rem_4rem] mask-[radial-gradient(ellipse_60%_50%_at_50%_50%,#000_70%,transparent_100%)] opacity-60"></div>
      
      <div class="absolute top-1/4 left-1/4 w-96 h-96 rounded-full bg-indigo-200/40 blur-[100px] animate-pulse"></div>
      <div class="absolute bottom-1/4 right-1/4 w-96 h-96 rounded-full bg-emerald-200/30 blur-[100px]"></div>

      <div class="w-full mx-auto grid grid-cols-1 lg:grid-cols-12 items-center gap-16 relative z-10 py-12">
        
        <div class="lg:col-span-8 space-y-8 text-left animate-fade-in">
          
          <div class="inline-flex items-center gap-2 text-xs font-mono uppercase tracking-wider text-emerald-700 bg-emerald-50 border border-emerald-200/60 px-4 py-1.5 rounded-full font-bold shadow-sm">
            <span class="flex h-2 w-2 relative">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
            </span>
            [ Ingeniería de Software + Diseño Gráfico + Experto Preprensa ]
          </div>      

          <h1 class="text-5xl md:text-6xl xl:text-6xl font-black tracking-tight text-slate-900 leading-[1.1] uppercase">
            Diseño impreso e interfaces, <br />
            <span class="text-transparent bg-clip-text bg-linear-to-r from-indigo-600 via-purple-600 to-violet-600 drop-shadow-sm">
              experto en preprensa digital y desarrollo de software,
            </span> <br />
            y audito su seguridad.
          </h1>

          <p class="text-lg md:text-xl text-slate-600 max-w-xl font-light leading-relaxed">         
            Especializado en optimizar flujos de producción digital, desarrollar sistemas de components atómicos y mitigar vulnerabilidades críticas en la experiencia del usuario.
          </p>

          <div class="flex flex-wrap gap-4 pt-2">
            <a 
              href="#creative-lab" 
              class="px-6 py-3.5 rounded-xl bg-slate-900 text-white font-mono text-sm font-bold tracking-wide hover:bg-indigo-600 hover:shadow-xl hover:shadow-indigo-600/20 transition-all duration-300 transform hover:-translate-y-0.5"
            >
              EXPLORAR_PROYECTOS ➔
            </a>
            <a 
              href="#contacto" 
              class="px-6 py-3.5 rounded-xl bg-white text-slate-700 border border-slate-200 font-mono text-sm font-semibold tracking-wide hover:bg-slate-50 hover:border-slate-300 transition-all duration-300"
            >
              [ Descargar_CV ]
            </a>
          </div>
        </div>

        <div class="lg:col-span-4 flex items-center justify-center relative transform transition-all duration-1000 ease-out opacity-0 translate-y-4 [animation-delay:300ms] style-running" style="animation: fadeIn 1s ease-out forwards;">
          <div class="relative group">
            <div class="absolute -inset-1 bg-linear-to-r from-indigo-500 to-emerald-400 rounded-3xl blur opacity-30 group-hover:opacity-60 transition duration-1000 group-hover:duration-200 motion-reduce:transition-none"></div>
            <div class="relative bg-white p-3 rounded-3xl shadow-2xl border border-slate-100">
              <img 
                src="/foto.png" 
                alt="Foto de perfil de Johan González" 
                class="aspect-4/5 w-full max-w-100 rounded-2xl object-cover grayscale contrast-115 hover:grayscale-0 transition-all duration-700 ease-out"
              />
              <div class="absolute bottom-6 left-6 bg-slate-900/90 backdrop-blur-md text-white font-mono text-[10px] tracking-widest uppercase py-1.5 px-3 rounded-lg border border-white/10 shadow-lg">
                Dev // Security // Design
              </div>
            </div>
          </div>
        </div>
          
      </div>
    </section>

    <div class="reveal opacity-0 translate-y-12 transition-all duration-1000 ease-out w-full">
      <AboutMe />
    </div>

    <section id="creative-lab" data-theme="light" class="reveal opacity-0 translate-y-12 py-32 bg-white text-slate-900 transition-all duration-1000 ease-out border-t border-slate-100 px-6 md:px-16 lg:px-24 w-full max-w-none">
      <div class="w-full space-y-16">
        
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 border-b border-slate-200 pb-8">
          <div class="space-y-3">
            <span class="text-xs font-mono uppercase tracking-widest text-indigo-600 bg-indigo-50 border border-indigo-100 px-3 py-1 rounded-full inline-block font-bold">
              [ CONTROL ESTRECHO DEL PÍXEL A LA TINTA ]
            </span>
            <h2 class="text-3xl md:text-5xl font-black tracking-tight text-slate-900 uppercase">
              Ecosistema Gráfico Industrial
            </h2>
          </div>
          <a href="/diseno" class="text-xs font-mono font-bold uppercase text-indigo-600 hover:text-indigo-800 transition-colors border border-slate-200 bg-slate-50 px-4 py-2 rounded-xl shadow-sm">
            Ver Laboratorio Gráfico →
          </a>
        </div>

        <DesignGallery limit={2} />

      </div>
    </section>

    <section id="software-security" data-theme="dark" class="reveal opacity-0 translate-y-12 py-32 bg-slate-950 text-slate-100 transition-all duration-1000 ease-out px-6 md:px-16 lg:px-24 w-full max-w-none border-t border-slate-900 motion-reduce:transition-none">
      <div class="w-full space-y-16">
        
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 border-b border-slate-900 pb-8">
          <div class="space-y-3">
            <span class="text-xs font-mono uppercase tracking-widest text-emerald-400 bg-emerald-950/30 border border-emerald-900/40 px-3 py-1 rounded-full inline-block font-bold">
              [ INGENIERÍA DE SOFTWARE & AUDITORÍA DE SEGURIDAD ]
            </span>
            <h2 class="text-3xl md:text-5xl font-black tracking-tight text-slate-100 uppercase">
              Soluciones Robustas y Seguras
            </h2>
          </div>
          <a href="/seguridad" class="text-xs font-mono font-bold uppercase text-emerald-400 hover:text-emerald-300 transition-colors border border-emerald-900/60 bg-emerald-950/10 px-4 py-2 rounded-xl shadow-lg">
            Acceder al Lab de Seguridad →
          </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 w-full">
          <ProjectCard 
            title="Auditoría de Vulnerabilidades Web (OWASP Top 10)"
            description="Detección, explotación controlada y parcheo estructural de fallos severos de inyección y fallos de sanitización en componentes frontend."
            tags={['Burp Suite', 'OWASP ZAP', 'Kali Linux', 'AppSec']}
            category="security"
            link="/seguridad"
          />
          <ProjectCard 
            title="Arquitectura de Nube Inmune"
            description="Diseño e implementación de infraestructuras en AWS aplicando políticas estrictas de acceso (IAM), bases de datos relacionales seguras (RDS) y hardening de servidores EC2."
            tags={['AWS', 'Cloud Security', 'IAM', 'Network Security']}
            category="security"
            link="/seguridad"
          />
        </div>

      </div>
    </section>

    <div class="reveal opacity-0 translate-y-12 transition-all duration-1000 ease-out w-full">
      <ContactForm />
    </div>

    <Footer />

  </main>
</BaseLayout>

<style>
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<script>
  function initScrollReveal() {
    const observerOptions = {
      root: null,
      rootMargin: '0px 0px -100px 0px', // Activa la visualización 100px antes del cruce de pantalla
      threshold: 0.08
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.remove('opacity-0', 'translate-y-12');
          observer.unobserve(entry.target); // Desconecta para congelar la sección visible
        }
      });
    }, observerOptions);

    const items = document.querySelectorAll('.reveal');
    items.forEach(item => observer.observe(item));
  }

  // Despliegue inmediato en carga clásica y re-enlazado dinámico en navegación SPA de Astro
  initScrollReveal();
  document.addEventListener('astro:page-load', initScrollReveal);
</script>