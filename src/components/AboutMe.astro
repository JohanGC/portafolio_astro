---
// SECCIÓN DE COMPILACIÓN (SERVER-SIDE)
// Aquí podríamos traer datos de una API o CMS si fuera necesario. Por ahora la estructura está lista.
---

<section 
  id="about-section" 
  data-theme="light" 
  class="min-h-screen py-32 w-full max-w-none px-6 md:px-16 lg:px-24 flex flex-col justify-center transition-colors duration-700"
>
  <div class="w-full space-y-12">

    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 border-b border-slate-200 pb-8 transition-colors duration-500" id="about-header-border">
      <div class="space-y-2">
        <span class="text-xs font-mono uppercase tracking-widest text-slate-500 font-bold">[ El Humano Detrás del Código ]</span>
        <h2 class="text-4xl md:text-6xl font-black tracking-tight" id="about-title">Sobre Mí</h2>
      </div>

      <div class="inline-flex p-1 rounded-xl bg-slate-100 border border-slate-200 shadow-inner transition-colors duration-500" id="perspective-toggle-container">
        <button
          id="btn-designer"
          class="px-4 py-2 text-xs font-mono font-bold uppercase tracking-wider rounded-lg transition-all duration-300 shadow-sm bg-white text-indigo-600"
        >
          Diseñador Gráfico
        </button>
        <button
          id="btn-engineer"
          class="px-4 py-2 text-xs font-mono font-bold uppercase tracking-wider rounded-lg transition-all duration-300 text-slate-500 hover:text-slate-800"
        >
          Ingeniero de Software
        </button>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start w-full">
      <div class="lg:col-span-5 space-y-6">
        <p class="text-base md:text-lg leading-relaxed font-light text-slate-700 transition-colors duration-500" id="about-description">
          Durante más de siete años he ejercido la producción gráfica digital avanzada, especializándome en la automatización de flujos de pre-prensa y empaques industriales mediante scripts e interfaces lógicas interactivas. Mi transición natural hacia la ingeniería de software me permite estructurar aplicaciones web óptimas, limpias y metodológicamente blindadas contra fallos lógicos.
        </p>
        
        <div class="pt-2">
          <p class="text-xs font-mono text-slate-400 uppercase tracking-widest">[ Enfoque Profesional Actual ]</p>
          <p class="text-sm font-semibold text-slate-800 mt-1 transition-colors duration-500" id="focus-text">Fusión Estética-Estructural, Automatización Gráfica y Sistemas Interactivos Avanzados.</p>
        </div>
      </div>

      <div class="lg:col-span-7">
        <div class="p-8 md:p-12 rounded-2xl border border-slate-200 bg-slate-50 transition-all duration-500 space-y-6" id="tech-spec-box">
          <div>
            <h3 class="text-xs font-mono font-bold uppercase tracking-[0.2em] text-indigo-600 transition-colors duration-500" id="spec-subtitle">
              Stack de Producción y Diseño Visual
            </h3>
            <p class="text-2xl font-black tracking-tight mt-1">Herramientas Avanzadas</p>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 pt-2 font-mono text-xs text-slate-600 transition-colors duration-500" id="skills-grid">
            <div class="space-y-2">
              <p class="font-bold text-slate-900 border-b border-slate-200 pb-1 flex justify-between"><span>Adobe Creative Suite</span> <span>[90%]</span></p>
              <p class="text-[11px] font-light">Especialista en flujos vectoriales masivos e interactividad en Acrobat.</p>
            </div>
            <div class="space-y-2">
              <p class="font-bold text-slate-900 border-b border-slate-200 pb-1 flex justify-between"><span>Pre-Prensa Industrial</span> <span>[95%]</span></p>
              <p class="text-[11px] font-light">Control estricto de tintas directas, sangrados y trapping automatizado.</p>
            </div>
            <div class="space-y-2">
              <p class="font-bold text-slate-900 border-b border-slate-200 pb-1 flex justify-between"><span>UI/UX Prototyping</span> <span>[85%]</span></p>
              <p class="text-[11px] font-light">Estructuración de componentes de alta fidelidad centrados en la usabilidad.</p>
            </div>
            <div class="space-y-2">
              <p class="font-bold text-slate-900 border-b border-slate-200 pb-1 flex justify-between"><span>Layout Semántico</span> <span>[90%]</span></p>
              <p class="text-[11px] font-light">Maquetación adaptativa robusta enfocada en la consistencia de marca.</p>
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>

<script>
  const btnDesigner = document.getElementById('btn-designer');
  const btnEngineer = document.getElementById('btn-engineer');
  const aboutSection = document.getElementById('about-section');
  const aboutHeaderBorder = document.getElementById('about-header-border');
  const toggleContainer = document.getElementById('perspective-toggle-container');
  const techSpecBox = document.getElementById('tech-spec-box');
  const specSubtitle = document.getElementById('spec-subtitle');
  const aboutTitle = document.getElementById('about-title');
  const aboutDescription = document.getElementById('about-description');
  const focusText = document.getElementById('focus-text');
  const skillsGrid = document.getElementById('skills-grid');

  if (btnDesigner && btnEngineer && aboutSection && aboutHeaderBorder && toggleContainer && techSpecBox && specSubtitle && aboutTitle && aboutDescription && focusText && skillsGrid) {
    
    btnDesigner.addEventListener('click', () => {
      btnDesigner.className = "px-4 py-2 text-xs font-mono font-bold uppercase tracking-wider rounded-lg transition-all duration-300 shadow-sm bg-white text-indigo-600";
      btnEngineer.className = "px-4 py-2 text-xs font-mono font-bold uppercase tracking-wider rounded-lg transition-all duration-300 text-slate-500 hover:text-slate-800";
      
      aboutSection.setAttribute('data-theme', 'light');
      aboutSection.className = "min-h-screen py-32 w-full max-w-none px-6 md:px-16 lg:px-24 flex flex-col justify-center transition-colors duration-700 bg-white text-slate-900";
      
      aboutHeaderBorder.className = "flex flex-col md:flex-row md:items-end justify-between gap-6 border-b border-slate-200 pb-8 transition-colors duration-500";
      toggleContainer.className = "inline-flex p-1 rounded-xl bg-slate-100 border border-slate-200 shadow-inner transition-colors duration-500";
      
      techSpecBox.className = "p-8 md:p-12 rounded-2xl border border-slate-200 bg-slate-50 transition-all duration-500 space-y-6";
      specSubtitle.className = "text-xs font-mono font-bold uppercase tracking-[0.2em] text-indigo-600 transition-colors duration-500";
      
      aboutTitle.className = "text-4xl md:text-6xl font-black tracking-tight text-slate-900";
      aboutDescription.className = "text-base md:text-lg leading-relaxed font-light text-slate-700 transition-colors duration-500";
      focusText.className = "text-sm font-semibold text-slate-800 mt-1 transition-colors duration-500";
      
      skillsGrid.className = "grid grid-cols-1 sm:grid-cols-2 gap-6 pt-2 font-mono text-xs text-slate-600 transition-colors duration-500";
      skillsGrid.innerHTML = `
        <div class="space-y-2">
          <p class="font-bold text-slate-900 border-b border-slate-200 pb-1 flex justify-between"><span>Adobe Creative Suite</span> <span>[90%]</span></p>
          <p class="text-[11px] font-light">Especialista en flujos vectoriales masivos e interactividad en Acrobat.</p>
        </div>
        <div class="space-y-2">
          <p class="font-bold text-slate-900 border-b border-slate-200 pb-1 flex justify-between"><span>Pre-Prensa Industrial</span> <span>[95%]</span></p>
          <p class="text-[11px] font-light">Control estricto de tintas directas, sangrados y trapping automatizado.</p>
        </div>
        <div class="space-y-2">
          <p class="font-bold text-slate-900 border-b border-slate-200 pb-1 flex justify-between"><span>UI/UX Prototyping</span> <span>[85%]</span></p>
          <p class="text-[11px] font-light">Estructuración de componentes de alta fidelidad centrados en la usabilidad.</p>
        </div>
        <div class="space-y-2">
          <p class="font-bold text-slate-900 border-b border-slate-200 pb-1 flex justify-between"><span>Layout Semántico</span> <span>[90%]</span></p>
          <p class="text-[11px] font-light">Maquetación adaptativa robusta enfocada en la consistencia de marca.</p>
        </div>
      `;
    });

    btnEngineer.addEventListener('click', () => {
      btnEngineer.className = "px-4 py-2 text-xs font-mono font-bold uppercase tracking-wider rounded-lg transition-all duration-300 shadow-sm bg-slate-800 text-emerald-400";
      btnDesigner.className = "px-4 py-2 text-xs font-mono font-bold uppercase tracking-wider rounded-lg transition-all duration-300 text-slate-400 hover:text-slate-200";
      
      aboutSection.setAttribute('data-theme', 'dark');
      aboutSection.className = "min-h-screen py-32 w-full max-w-none px-6 md:px-16 lg:px-24 flex flex-col justify-center transition-colors duration-700 bg-slate-950 text-slate-100";
      
      aboutHeaderBorder.className = "flex flex-col md:flex-row md:items-end justify-between gap-6 border-b border-slate-800 pb-8 transition-colors duration-500";
      toggleContainer.className = "inline-flex p-1 rounded-xl bg-slate-900 border border-slate-800 shadow-inner transition-colors duration-500";
      
      techSpecBox.className = "p-8 md:p-12 rounded-2xl border border-slate-800 bg-slate-900/50 transition-all duration-500 space-y-6 shadow-2xl shadow-emerald-500/5";
      specSubtitle.className = "text-xs font-mono font-bold uppercase tracking-[0.2em] text-emerald-400 transition-colors duration-500";
      
      aboutTitle.className = "text-4xl md:text-6xl font-black tracking-tight text-slate-100";
      aboutDescription.className = "text-base md:text-lg leading-relaxed font-light text-slate-400 transition-colors duration-500";
      focusText.className = "text-sm font-semibold text-emerald-400 mt-1 transition-colors duration-500";
      
      skillsGrid.className = "grid grid-cols-1 sm:grid-cols-2 gap-6 pt-2 font-mono text-xs text-slate-400 transition-colors duration-500";
      skillsGrid.innerHTML = `
        <div class="space-y-2">
          <p class="font-bold text-slate-200 border-b border-slate-800 pb-1 flex justify-between"><span>Desarrollo Web Fullstack</span> <span>[85%]</span></p>
          <p class="text-[11px] font-light">Ecosistemas interactivos escalables con Astro, Tailwind y TypeScript.</p>
        </div>
        <div class="space-y-2">
          <p class="font-bold text-slate-200 border-b border-slate-800 pb-1 flex justify-between"><span>Seguridad Ofensiva</span> <span>[80%]</span></p>
          <p class="text-[11px] font-light">Análisis de vulnerabilidades web (OWASP), interceptación con Burp Suite y Kali Linux.</p>
        </div>
        <div class="space-y-2">
          <p class="font-bold text-slate-200 border-b border-slate-800 pb-1 flex justify-between"><span>Métodos Numéricos</span> <span>[75%]</span></p>
          <p class="text-[11px] font-light">Resolución e interpolación matemática computacional aplicada en hojas de cálculo.</p>
        </div>
        <div class="space-y-2">
          <p class="font-bold text-slate-200 border-b border-slate-800 pb-1 flex justify-between"><span>Arquitectura de Sistemas</span> <span>[80%]</span></p>
          <p class="text-[11px] font-light">Diseño modular de software, patrones arquitectónicos y control con Git/GitHub.</p>
        </div>
      `;
    });
  }
</script>