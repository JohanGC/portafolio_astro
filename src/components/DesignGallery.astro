---
// src/components/DesignGallery.astro
const { limit } = Astro.props;

const projects = [
  {
    id: "cadena",
    title: "Cadena S.A.",
    category: "Preprensa & Diseño Gráfico",
    shortDesc: "Diseño y montaje de comunicaciones impresas y digitales.",
    image: "/images/cadena_0.png",
    tags: ["Acrobat", "JavaScript", "Industrial Printing"],
  },
  {
    id: "asaki",
    title: "Marca ASAKI-FIT",
    category: "Diseño Gráfico",
    shortDesc: "Diseño de logo ilustrado.",
    image: "/images/Asaki-Fit_1.png",
    tags: ["Illustrator", "Photoshop", "Branding", "Logo Design"],
  },
  {
    id: "iamsterdam",
    title: "Marca I Amsterdam",
    category: "Diseño Gráfico",
    shortDesc: "Diseño de logo ilustrado.",
    image: "/images/IAmsterdam_4.png",
    tags: ["Illustrator", "Photoshop", "Branding", "Logo Design"],
  },
  {
    id: "prepress-auto",
    title: "Automatización de Preprensa Digital",
    category: "Ingeniería Gráfica",
    shortDesc: "Optimización de flujos de trabajo masivos para impresión industrial.",
    image: "https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?auto=format&fit=crop&w=600&q=80",
    tags: ["Acrobat", "JavaScript", "Industrial Printing"],
  },
    {
    id: "web",
    title: "Pagina Web X",
    category: "Ingeniería",
    shortDesc: "Optimización de flujos de trabajo masivos para impresión industrial.",
    image: "https://images.unsplash.com/photo-1620641788421-7a1c342ea42e?auto=format&fit=crop&w=600&q=80",
    tags: ["Acrobat", "JavaScript", "Industrial Printing"],
  },
      {
    id: "prepress-auto",
    title: "Preprensa Digital",
    category: "Ingeniería",
    shortDesc: "Optimización de flujos de trabajo masivos para impresión industrial.",
    image: "https://images.unsplash.com/photo-1620641788421-7a1c342ea42e?auto=format&fit=crop&w=600&q=80",
    tags: ["Acrobat", "JavaScript", "Industrial Printing"],
  }
];

const designProjects = limit ? projects.slice(0, limit) : projects;

---

<div class="w-full space-y-12">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-start">
    {designProjects.map((project) => (
      <a 
        href={`/projects/${project.id}`}
        class="group bg-white rounded-3xl border border-slate-200 overflow-hidden transition-all duration-500 ease-in-out hover:shadow-md flex flex-col p-8 space-y-6 select-none"
      >
        {/* CORREGIDO: aspect-[16/10] cambiado por aspect-16/10 */}
        <div class="aspect-16/10 rounded-2xl overflow-hidden bg-slate-100 border border-slate-100 relative">
          <img 
            src={project.image} 
            alt={project.title}
            class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.02]"
            loading="lazy"
          />
          <div class="absolute top-4 left-4">
            <span class="text-[10px] font-mono uppercase tracking-widest text-indigo-700 bg-indigo-50/90 backdrop-blur-sm border border-indigo-100 px-2.5 py-1 rounded-md font-bold">
              {project.category}
            </span>
          </div>
        </div>

        <div class="space-y-2">
          <h3 class="text-2xl font-bold tracking-tight text-slate-900 flex justify-between items-center">
            {project.title}
            <span class="text-xs font-mono text-indigo-600 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
              [ VER_PROYECTO -> ]
            </span>
          </h3>
          <p class="text-sm text-slate-500 font-light leading-relaxed">{project.shortDesc}</p>
        </div>

        <div class="flex flex-wrap gap-2 pt-2">
          {project.tags.map((tag) => (
            <span class="text-[10px] font-mono px-2 py-0.5 rounded bg-slate-100 text-slate-600 border border-slate-200/60">
              {tag}
            </span>
          ))}
        </div>
      </a>
    ))}
  </div>
</div>