---
// src/components/Footer.astro
const currentYear = new Date().getFullYear();
---

<footer class="bg-slate-950 border-t border-slate-900 py-8 px-6 text-slate-500 font-mono text-[11px]">
  <div class="max-w-5xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4">
    
    <div>
      <p>© {currentYear} Johan Gonzalez Castaño. Todos los derechos reservados.</p>
      <p class="text-[9px] text-slate-700 mt-1">Construido con Astro, TypeScript & Tailwind CSS.</p>
    </div>

    <div class="flex items-center gap-6 text-slate-400">
      <a 
        href="https://github.com" 
        target="_blank" 
        rel="noopener noreferrer" 
        class="hover:text-indigo-400 transition-colors uppercase tracking-wider"
      >
        GitHub
      </a>
      <a 
        href="https://linkedin.com" 
        target="_blank" 
        rel="noopener noreferrer" 
        class="hover:text-indigo-400 transition-colors uppercase tracking-wider"
      >
        LinkedIn
      </a>
      <span class="text-slate-800">|</span>
      <span class="text-emerald-500/60 text-[10px]">
        [ PGP_KEY: SIGNED ]
      </span>
    </div>

  </div>
</footer>