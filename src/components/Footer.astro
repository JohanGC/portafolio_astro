---
// SECCIÓN DE COMPILACIÓN (SERVER-SIDE)
const currentYear = new Date().getFullYear();
---

<footer class="bg-slate-950 text-slate-500 font-mono text-xs py-12 border-t border-slate-900 px-6">
  <div class="max-w-5xl mx-auto flex flex-col md:flex-row items-center justify-between gap-6">
    
    <div class="text-center md:text-left space-y-1">
      <p class="text-slate-400 font-sans font-medium">
        &copy; {currentYear} Johan González Castaño. Todos los derechos reservados.
      </p>
      <p class="text-[10px] text-slate-600">
        Construido nativamente con Astro, TypeScript & Tailwind CSS v4.
      </p>
    </div>

    <div class="flex items-center gap-6 text-slate-400">
      <a href="https://github.com" target="_blank" rel="noopener noreferrer" class="hover:text-emerald-400 transition-colors">
        GitHub
      </a>
      <a href="https://linkedin.com" target="_blank" rel="noopener noreferrer" class="hover:text-indigo-400 transition-colors">
        LinkedIn
      </a>
      <a href="https://johangc.com" class="hover:text-white border border-slate-800 px-3 py-1 rounded-md bg-slate-900/50 transition-colors">
        johangc.com
      </a>
    </div>

  </div>
</footer>