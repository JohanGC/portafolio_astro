---
// src/components/FloatingNav.astro
---

<nav class="fixed top-6 left-1/2 -translate-x-1/2 z-50 bg-white/80 dark:bg-slate-900/80 backdrop-blur-xl border border-slate-200/50 dark:border-slate-800/50 px-6 py-3 rounded-full shadow-xl flex items-center gap-6 text-sm font-medium text-slate-600 dark:text-slate-300 transition-all duration-300 hover:shadow-2xl hover:border-slate-300 dark:hover:border-slate-700">
  
  <a href="/" class="hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors py-1 px-3 rounded-full hover:bg-slate-50 dark:hover:bg-slate-800/60">
    Home
  </a>

  <div class="relative group py-1 px-3 rounded-full hover:bg-slate-50 dark:hover:bg-slate-800/60 cursor-pointer">
    <span class="flex items-center gap-1 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors select-none">
      Projects
      <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 transition-transform duration-300 group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
      </svg>
    </span>

    <div class="absolute top-full left-1/2 -translate-x-1/2 mt-3 w-44 opacity-0 pointer-events-none translate-y-3 group-hover:opacity-100 group-hover:pointer-events-auto group-hover:translate-y-0 transition-all duration-300 ease-out z-20
                before:content-[''] before:absolute before:-top-3 before:left-0 before:w-full before:h-3">
    
      <div class="bg-white dark:bg-slate-900 border border-slate-200/80 dark:border-slate-800 rounded-2xl shadow-xl p-2 relative">
          
        <div class="absolute w-2.5 h-2.5 bg-white dark:bg-slate-900 border-r border-b border-slate-200/80 dark:border-slate-800 -top-1.5 left-1/2 -translate-x-1/2 rotate-45 z-10"></div>
          
        <a 
          href="/diseno" 
          class="block px-4 py-2.5 text-xs font-mono uppercase tracking-wider text-slate-700 dark:text-slate-300 hover:bg-indigo-50 dark:hover:bg-indigo-950/50 hover:text-indigo-700 dark:hover:text-indigo-400 rounded-xl transition-colors font-bold"
        >
          // Diseño
        </a>
        <a 
          href="/seguridad" 
          class="block px-4 py-2.5 text-xs font-mono uppercase tracking-wider text-slate-700 dark:text-slate-300 hover:bg-emerald-50 dark:hover:bg-emerald-950/50 hover:text-emerald-600 dark:hover:text-emerald-400 rounded-xl transition-colors font-bold"
        >
          // Ciberseguridad
        </a>
      </div>
    </div>
  </div>

  <a href="/#contact" class="hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors py-1 px-3 rounded-full hover:bg-slate-50 dark:hover:bg-slate-800/60">
    Contacto
  </a>

</nav>