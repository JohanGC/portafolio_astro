---
// src/components/ContactForm.astro
---

<section 
  id="contact" 
  data-theme="dark" 
  class="py-24 px-6 bg-slate-950 text-slate-100 relative overflow-hidden transition-colors duration-500 border-t border-slate-900"
>
  <div class="max-w-4xl mx-auto relative z-10 grid grid-cols-1 md:grid-cols-12 gap-12 items-center">
    
    <div class="md:col-span-5 space-y-6">
      <div class="space-y-2">
        <span class="text-[10px] font-mono uppercase tracking-widest text-indigo-400 bg-indigo-950/40 border border-indigo-900/50 px-2.5 py-0.5 rounded-md inline-block">
          // ESTABLECER_CONEXIÓN
        </span>
        <h2 class="text-3xl md:text-4xl font-black tracking-tight text-slate-100">
          ¿Tienes un proyecto en mente?
        </h2>
      </div>
      <p class="text-sm text-slate-400 font-light leading-relaxed">
        Estoy disponible para colaborar en auditorías de seguridad de aplicaciones (AppSec), desarrollo de software robusto frontend/backend y optimización automatizada de flujos de producción gráfica.
      </p>
      <div class="pt-4 font-mono text-xs text-slate-500 space-y-2">
        <p>➔ RESPONSE_TIME &lt; 24H</p>
        <p>➔ DISPONIBILIDAD: REMOTO / BOGOTÁ / MEDELLÍN</p>
      </div>
    </div>

    <div class="md:col-span-7">
      <form 
        id="secure-contact-form" 
        class="bg-slate-900/50 border border-slate-900 rounded-2xl p-6 md:p-8 space-y-5 shadow-2xl backdrop-blur-sm"
        autocomplete="off"
      >
        <div class="hidden" aria-hidden="true">
          <input 
            type="text" 
            name="system_honeypot_id" 
            id="form-honeypot" 
            tabindex="-1" 
            autocomplete="off" 
          />
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="space-y-2">
            <label for="form-name" class="font-mono text-[11px] uppercase tracking-wider text-slate-400 block">01. Nombre</label>
            <input 
              type="text" 
              id="form-name" 
              name="name" 
              required
              class="w-full bg-slate-950 border border-slate-800 rounded-xl px-4 py-3 text-sm text-slate-100 placeholder-slate-600 focus:outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 transition-all duration-300"
              placeholder="Tu nombre completo"
            />
          </div>
          <div class="space-y-2">
            <label for="form-email" class="font-mono text-[11px] uppercase tracking-wider text-slate-400 block">02. Email Corporativo</label>
            <input 
              type="email" 
              id="form-email" 
              name="email" 
              required
              class="w-full bg-slate-950 border border-slate-800 rounded-xl px-4 py-3 text-sm text-slate-100 placeholder-slate-600 focus:outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 transition-all duration-300"
              placeholder="correo@empresa.com"
            />
          </div>
        </div>

        <div class="space-y-2">
          <label for="form-subject" class="font-mono text-[11px] uppercase tracking-wider text-slate-400 block">03. Asunto</label>
          <input 
            type="text" 
            id="form-subject" 
            name="subject" 
            required
            class="w-full bg-slate-950 border border-slate-800 rounded-xl px-4 py-3 text-sm text-slate-100 placeholder-slate-600 focus:outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 transition-all duration-300"
            placeholder="Ej: Auditoría de Software / Propuesta de Proyecto"
          />
        </div>

        <div class="space-y-2">
          <label for="form-message" class="font-mono text-[11px] uppercase tracking-wider text-slate-400 block">04. Mensaje Encriptado en Tránsito</label>
          <textarea 
            id="form-message" 
            name="message" 
            rows="4" 
            required
            class="w-full bg-slate-950 border border-slate-800 rounded-xl px-4 py-3 text-sm text-slate-100 placeholder-slate-600 focus:outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 transition-all duration-300 resize-none"
            placeholder="Describe brevemente los requerimientos técnicos..."
          ></textarea>
        </div>

        <div class="pt-2 flex flex-col sm:flex-row items-center justify-between gap-4">
          <span id="form-status-msg" class="font-mono text-[11px] font-bold block min-h-[16px]"></span>
          
          <button 
            type="submit"
            class="w-full sm:w-auto px-6 py-3 bg-gradient-to-r from-indigo-600 to-violet-600 text-white font-mono text-xs font-bold uppercase tracking-wider rounded-xl hover:from-indigo-500 hover:to-violet-500 active:scale-98 transition-all duration-300 shadow-lg shadow-indigo-500/10 cursor-pointer"
          >
            Enviar Mensaje Seguro ➔
          </button>
        </div>
      </form>
    </div>
  </div>

  <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-indigo-500/5 rounded-full blur-3xl pointer-events-none z-0"></div>
</section>

<script>
  // CONTROL LÓGICO DEL FORMULARIO CLIENT-SIDE
  const contactForm = document.getElementById('secure-contact-form') as HTMLFormElement | null;
  const statusMsg = document.getElementById('form-status-msg');
  const honeypot = document.getElementById('form-honeypot') as HTMLInputElement | null;

  if (contactForm && statusMsg) {
    contactForm.addEventListener('submit', async (e) => {
      e.preventDefault();

      // 1. EVALUAR MITIGACIÓN HONEYPOT
      if (honeypot && honeypot.value !== '') {
        statusMsg.className = "font-mono text-[11px] text-red-400 font-bold bg-red-950/30 border border-red-900/50 px-3 py-1 rounded";
        statusMsg.textContent = "[!] BOT_SPAM_DETECTED: Petición descartada.";
        return;
      }

      // 2. CAMBIO DE ESTADO VISUAL (PROCESANDO)
      statusMsg.className = "font-mono text-[11px] text-indigo-400 bg-indigo-950/30 border border-indigo-900/50 px-3 py-1 rounded animate-pulse";
      statusMsg.textContent = "[*] SANITIZING & SENDING...";

      // Recolección de Datos
      const formData = new FormData(contactForm);
      const payload = Object.fromEntries(formData.entries());

      try {
        // NOTA TÉCNICA: Aquí puedes acoplar tu endpoint real (Formspree, Web3Forms o tu propia API Route de Astro)
        // Por ahora simulamos una respuesta exitosa con delay de red de 1.2s para la demo interactiva.
        await new Promise(resolve => setTimeout(resolve, 1200));

        // 3. CAMBIO DE ESTADO (ÉXITO)
        statusMsg.className = "font-mono text-[11px] text-emerald-400 font-bold bg-emerald-950/30 border border-emerald-900/50 px-3 py-1 rounded animate-fade-in";
        statusMsg.textContent = "[✔] TRANSMISIÓN EXITOSA: Payload recibido.";
        contactForm.reset();
        
        // Limpiar mensaje tras 5 segundos
        setTimeout(() => { statusMsg.textContent = ""; statusMsg.className = ""; }, 5000);

      } catch (error) {
        statusMsg.className = "font-mono text-[11px] text-red-400 font-bold bg-red-950/30 border border-red-900/50 px-3 py-1 rounded";
        statusMsg.textContent = "[✕] ERROR: Fallo en el socket de red.";
      }
    });
  }
</script>