---
// SECCIÓN DE COMPILACIÓN (SERVER-SIDE)
---

<section id="contact-section" data-theme="dark" class="min-h-screen py-24 px-6 flex flex-col justify-center transition-colors duration-700 bg-slate-950 text-slate-100">
  <div class="max-w-4xl mx-auto w-full grid grid-cols-1 md:grid-cols-12 gap-12 items-start">
    
    <div class="md:col-span-5 space-y-6">
      <div class="space-y-2">
        <span class="text-xs font-mono uppercase tracking-widest text-emerald-400 font-bold">$ contact --init</span>
        <h2 class="text-4xl font-black tracking-tight text-white">Construyamos algo juntos</h2>
      </div>
      <p class="text-sm text-slate-400 font-light leading-relaxed">
        Ya sea que necesites automatizar un flujo complejo de pre-prensa, auditar la seguridad de tu aplicación web o diseñar un sistema de diseño desde cero, mi bandeja de entrada está abierta.
      </p>
      <div class="pt-4 space-y-3 font-mono text-xs text-slate-300">
        <p class="flex items-center gap-2">
          <span class="text-emerald-400">📍</span> Medellín, Colombia
        </p>
        <p class="flex items-center gap-2">
          <span class="text-emerald-400">🔒</span> Llave PG: <span class="text-slate-500">0x7F3A2B...</span>
        </p>
      </div>
    </div>

    <div class="md:col-span-7 bg-slate-900/40 border border-slate-800 p-8 rounded-2xl shadow-xl">
      <form id="secure-form" class="space-y-6" action="#" method="POST">
        
        <div class="hidden" aria-hidden="true">
          <label for="username_hp">No rellenar este campo si eres humano:</label>
          <input type="text" id="username_hp" name="username_hp" tabindex="-1" autocomplete="off" />
        </div>

        <div class="space-y-2">
          <label for="form-name" class="block text-xs font-mono uppercase tracking-wider text-slate-400 font-bold">Nombre Completo</label>
          <input 
            type="text" 
            id="form-name" 
            name="name" 
            required 
            placeholder="Ej. Alexander Pierce"
            class="w-full bg-slate-950/60 border border-slate-800 rounded-xl px-4 py-3 text-sm text-slate-100 placeholder-slate-600 focus:outline-none focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 transition-all"
          />
        </div>

        <div class="space-y-2">
          <label for="form-email" class="block text-xs font-mono uppercase tracking-wider text-slate-400 font-bold">Correo Electrónico</label>
          <input 
            type="email" 
            id="form-email" 
            name="email" 
            required 
            placeholder="alexander@empresa.com"
            class="w-full bg-slate-950/60 border border-slate-800 rounded-xl px-4 py-3 text-sm text-slate-100 placeholder-slate-600 focus:outline-none focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 transition-all"
          />
        </div>

        <div class="space-y-2">
          <label for="form-message" class="block text-xs font-mono uppercase tracking-wider text-slate-400 font-bold">Mensaje / Requerimientos del Proyecto</label>
          <textarea 
            id="form-message" 
            name="message" 
            rows="4" 
            required 
            placeholder="Describe brevemente los objetivos técnicos o estéticos de tu proyecto..."
            class="w-full bg-slate-950/60 border border-slate-800 rounded-xl px-4 py-3 text-sm text-slate-100 placeholder-slate-600 focus:outline-none focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 transition-all resize-none"
          ></textarea>
        </div>

        <button 
          type="submit" 
          id="btn-submit-form"
          class="w-full bg-slate-100 hover:bg-emerald-400 text-slate-950 font-mono font-bold uppercase tracking-wider py-3.5 rounded-xl transition-all duration-300 transform hover:-translate-y-0.5 shadow-md flex items-center justify-center gap-2"
        >
          <span>Desplegar Mensaje</span>
          <span class="font-sans text-sm">🚀</span>
        </button>

      </form>
    </div>

  </div>
</section>

<script>
  // CLIENT-SIDE VALIDATION & HONEYPOT AUDIT
  const contactForm = document.getElementById('secure-form') as HTMLFormElement;
  const submitButton = document.getElementById('btn-submit-form');

  if (contactForm && submitButton) {
    contactForm.addEventListener('submit', (event) => {
      event.preventDefault(); // Detener recarga nativa para control asíncrono
      
      // 1. Validar Honeypot
      const honeypotInput = document.getElementById('username_hp') as HTMLInputElement;
      if (honeypotInput && honeypotInput.value !== "") {
        console.warn("Spam bot detectado por el mecanismo Honeypot.");
        alert("Envío bloqueado por motivos de seguridad.");
        return; // Detiene la ejecución sin avisarle al bot
      }

      // 2. Simulación de feedback visual durante el envío (UX fluida)
      const originalText = submitButton.innerHTML;
      submitButton.innerHTML = `<span class="animate-pulse">Procesando petición... 📡</span>`;
      submitButton.setAttribute('disabled', 'true');

      // Aquí puedes conectar servicios como Formspree, Netlify Forms o tu propia API
      setTimeout(() => {
        alert("¡Mensaje enviado con éxito! Me comunicaré contigo a la brevedad.");
        contactForm.reset();
        submitButton.innerHTML = originalText;
        submitButton.removeAttribute('disabled');
      }, 1500);
    });
  }
</script>