---
// src/components/ContactForm.astro
---

<section 
  id="contact" 
  data-theme="dark" 
  class="py-32 w-full max-w-none px-6 md:px-16 lg:px-24 bg-slate-950 text-slate-100 relative overflow-hidden transition-colors duration-500 border-t border-slate-900"
>
  <div class="w-full relative z-10 grid grid-cols-1 lg:grid-cols-12 gap-16 items-center">
    
    <div class="lg:col-span-5 space-y-6">
      <div class="space-y-2">
        <span class="text-[10px] font-mono uppercase tracking-widest text-indigo-400 bg-indigo-950/40 border border-indigo-900/50 px-2.5 py-0.5 rounded-md inline-block">
          // ESTABLECER_CONEXIÓN
        </span>
        <h2 class="text-3xl md:text-5xl font-black tracking-tight text-slate-100">
          ¿Tienes un proyecto en mente?
        </h2>
      </div>
      <p class="text-sm text-slate-400 font-light leading-relaxed">
        Estoy disponible para colaborar en auditorías de seguridad de aplicaciones (AppSec), desarrollo de software robusto frontend/backend y optimización automatizada de flujos de producción gráfica.
      </p>
      <div class="pt-4 font-mono text-xs text-slate-400 space-y-2">
        <p class="flex items-center gap-2">
          <span class="text-indigo-400">⚡ INFRAESTRUCTURA:</span> SSL / TLS Blindado
        </p>
        <p class="flex items-center gap-2">
          <span class="text-emerald-400">🔒 VALIDACIÓN:</span> Sanitización activa de inputs en cliente
        </p>
      </div>
    </div>

    <div class="lg:col-span-7 w-full">
      <form id="secure-contact-form" class="bg-slate-900/40 border border-slate-900 rounded-2xl p-8 md:p-12 space-y-6 shadow-2xl backdrop-blur-sm">
        
        <div class="hidden">
          <label for="security_token">Dejar en blanco</label>
          <input type="text" id="security_token" name="security_token" autocomplete="off" />
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          <div class="space-y-2">
            <label for="name" class="block font-mono text-[11px] text-slate-400 uppercase tracking-wider font-bold">01. Identificación / Nombre</label>
            <input 
              type="text" 
              id="name" 
              name="name" 
              required 
              maxlength="80"
              placeholder="Johan Gonzalez"
              class="w-full bg-slate-950 border border-slate-800 rounded-xl px-4 py-3 text-sm text-slate-200 placeholder-slate-700 focus:outline-none focus:border-indigo-500 transition-colors font-sans"
            />
          </div>
          <div class="space-y-2">
            <label for="email" class="block font-mono text-[11px] text-slate-400 uppercase tracking-wider font-bold">02. Canal de Retorno / Correo</label>
            <input 
              type="email" 
              id="email" 
              name="email" 
              required 
              placeholder="johan@cadena.com.co"
              class="w-full bg-slate-950 border border-slate-800 rounded-xl px-4 py-3 text-sm text-slate-200 placeholder-slate-700 focus:outline-none focus:border-indigo-500 transition-colors font-sans"
            />
          </div>
        </div>

        <div class="space-y-2">
          <label for="message" class="block font-mono text-[11px] text-slate-400 uppercase tracking-wider font-bold">03. Payload / Detalles del Requerimiento</label>
          <textarea 
            id="message" 
            name="message" 
            rows="5" 
            required
            maxlength="1500"
            placeholder="Escribe los detalles de tu proyecto o requerimiento técnico aquí..."
            class="w-full bg-slate-950 border border-slate-800 rounded-xl px-4 py-3 text-sm text-slate-200 placeholder-slate-700 focus:outline-none focus:border-indigo-500 transition-colors font-sans resize-none"
          ></textarea>
        </div>

        <div class="flex flex-col sm:flex-row items-center justify-between gap-4 pt-2">
          <div id="form-status-msg" class="font-mono text-[11px]"></div>
          
          <button 
            type="submit"
            class="w-full sm:w-auto px-8 py-3.5 bg-indigo-600 hover:bg-indigo-500 text-white font-mono text-xs font-bold uppercase tracking-widest rounded-xl transition-all duration-300 shadow-lg shadow-indigo-600/10 active:scale-98 cursor-pointer"
          >
            Transmitir Mensaje Safe ➔
          </button>
        </div>

      </form>
    </div>
  </div>
</section>

<script>
  const contactForm = document.getElementById('secure-contact-form') as HTMLFormElement;
  const statusMsg = document.getElementById('form-status-msg');

  if (contactForm && statusMsg) {
    contactForm.addEventListener('submit', async (e) => {
      e.preventDefault();

      // 1. ANÁLISIS HONEYPOT (Mitigación Básica de Bots)
      const honeypot = (document.getElementById('security_token') as HTMLInputElement).value;
      if (honeypot) {
        statusMsg.className = "font-mono text-[11px] text-red-400 bg-red-950/30 border border-red-900/50 px-3 py-1 rounded";
        statusMsg.textContent = "[!] SPAM_BOT_DETECTED: Petición descartada.";
        return;
      }

      // 2. CAMBIO DE ESTADO VISUAL (PROCESANDO)
      statusMsg.className = "font-mono text-[11px] text-indigo-400 bg-indigo-950/30 border border-indigo-900/50 px-3 py-1 rounded animate-pulse";
      statusMsg.textContent = "[*] SANITIZING & SENDING...";

      const formData = new FormData(contactForm);
      const payload = Object.fromEntries(formData.entries());

      try {
        // Simulación controlada de respuesta asíncrona de servidor (1.2s de retraso)
        await new Promise(resolve => setTimeout(resolve, 1200));

        // 3. CAMBIO DE ESTADO (ÉXITO)
        statusMsg.className = "font-mono text-[11px] text-emerald-400 font-bold bg-emerald-950/30 border border-emerald-900/50 px-3 py-1 rounded animate-fade-in";
        statusMsg.textContent = "[✔] TRANSMISIÓN EXITOSA: Payload recibido.";
        contactForm.reset();
        
        setTimeout(() => { statusMsg.textContent = ""; statusMsg.className = ""; }, 5000);

      } catch (error) {
        statusMsg.className = "font-mono text-[11px] text-red-400 bg-red-950/30 border border-red-900/50 px-3 py-1 rounded";
        statusMsg.textContent = "[❌] ERROR_FAIL: Falla en la transmisión del paquete.";
      }
    });
  }
</script>